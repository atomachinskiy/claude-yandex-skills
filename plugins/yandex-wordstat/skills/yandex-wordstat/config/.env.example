# yandex-wordstat — dual-backend configuration

# Backend selection: legacy | cloud | (omit for auto)
# Auto picks cloud if SA key is configured, else legacy.
# YANDEX_WORDSTAT_BACKEND=legacy

# === LEGACY BACKEND (Wordstat OAuth API) ===
# Approved YANDEX_WORDSTAT_TOKEN от приложения с одобренной заявкой в кабинете Директа.
# Yandex stopped onboarding new users — only existing approved apps still work.
# Если этого токена нет, скилл попытается использовать общий токен из yandex-auth (~/.claude/secrets/yandex-app.json) как Bearer.
# YANDEX_WORDSTAT_TOKEN=

# === CLOUD BACKEND (Yandex Cloud Search API v2) ===
# Для новых пользователей. Требует Service Account в Yandex Cloud с ролью search-api.user.
# YANDEX_CLOUD_FOLDER_ID=b1g0123456789abc
# YANDEX_CLOUD_SA_KEY_FILE=/Users/$USER/.claude/secrets/yandex-cloud-sa-key.json
