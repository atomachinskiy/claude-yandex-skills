# yandex-tracker requires organization context.
# Choose ONE of these:

# Option 1 — Yandex 360 organization
# YANDEX_TRACKER_ORG_ID=12345

# Option 2 — Yandex Cloud organization (requires Cloud Tracker subscription)
# YANDEX_TRACKER_CLOUD_ORG_ID=bpfaaaaaaaaaaaaaaaaa

# Find your org_id at https://tracker.yandex.ru/admin/orgs (top-right user menu).
